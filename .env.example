"""
环境配置模板 - .env.example
复制此文件为 .env 并填入实际配置

使用方式:
1. cp .env.example .env
2. 编辑 .env 文件，填入实际的配置值
3. 系统会自动从 .env 加载环境变量
"""

# ==================== Flask应用配置 ====================

# 应用模式 (development/production)
FLASK_ENV=development

# 调试模式 (True/False)
DEBUG=True

# 密钥配置 (生产环境必须修改！)
SECRET_KEY=your-super-secret-key-change-in-production-please

# 服务器配置
HOST=0.0.0.0
PORT=5000

# 允许的CORS源 (多个用逗号分隔)
ALLOWED_ORIGINS=http://localhost:5000,http://localhost:3000,http://127.0.0.1:5000

# ==================== 数据库配置 ====================

# SQLite 数据库路径 (相对项目目录)
DATABASE_PATH=data/database/finance.db

# 数据库连接池配置
DB_POOL_SIZE=10
DB_POOL_MAX_OVERFLOW=20
DB_POOL_RECYCLE=3600

# ==================== 数据源配置 ====================

# Tushare API Token (必需！)
# 注册地址: https://tushare.pro/register?reg=1
# 注意: 这是示例token，请替换为实际的token
TUSHARE_TOKEN=87985a35b6278f37cc3f854b012aa1d9da716a1d9601094c24bc2b9b

# NewsAPI Key (可选，用于新闻采集)
# 注册地址: https://newsapi.org/register
NEWSAPI_KEY=your-newsapi-key-here

# Yahoo Finance 启用状态 (用于港股/美股/黄金数据采集)
YAHOO_FINANCE_ENABLED=True

# ==================== 采集配置 ====================

# 请求超时时间 (秒)
REQUEST_TIMEOUT=10

# 重试次数
MAX_RETRIES=3

# 请求间隔 (秒) - 防止API速率限制
REQUEST_DELAY=0.3

# 缓存有效期 (秒) - 5分钟
CACHE_TTL=300

# 全市场采集开关 (True/False)
USE_FULL_MARKET=True

# 股票池最大数量
MAX_A_STOCKS=5000
MAX_HK_STOCKS=2500
MAX_US_STOCKS=500

# ==================== 数据保留配置 ====================

# 原始数据保留天数 (2年)
RAW_DATA_RETENTION_DAYS=730

# 日志保留天数 (3个月)
LOG_RETENTION_DAYS=90

# 备份保留天数
BACKUP_RETENTION_DAYS=30

# ==================== 定时任务配置 ====================

# 实时采集间隔 (秒) - 5分钟
COLLECT_REAL_TIME_INTERVAL=300

# 日间数据采集时间 (HH:MM) - 收盘后
COLLECT_DAILY_TIME=15:30

# 基金净值采集时间
COLLECT_FUND_TIME=20:30

# 新闻采集间隔 (秒) - 4小时
COLLECT_NEWS_INTERVAL=14400

# 模型重训练 (day和hour)
MODEL_RETRAIN_DAY=sun
MODEL_RETRAIN_HOUR=2

# ==================== 预警配置 ====================

# 预警去重时间 (小时)
WARNING_DEDUP_HOURS=24

# 日跌幅阈值 (例: 0.05 表示 -5%)
DAILY_DROP_THRESHOLD=0.05

# 日涨幅阈值
DAILY_RISE_THRESHOLD=0.07

# 单资产最大持仓占比
MAX_SINGLE_ASSET_RATIO=0.20

# ==================== 日志配置 ====================

# 日志级别 (DEBUG/INFO/WARNING/ERROR/CRITICAL)
LOG_LEVEL=INFO

# 控制台日志级别
CONSOLE_LOG_LEVEL=INFO

# 日志文件路径
LOG_FILE=logs/app.log

# 日志格式
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# 日志日期格式
LOG_DATE_FORMAT=%Y-%m-%d %H:%M:%S

# ==================== 邮件提醒配置 (可选) ====================

# 是否启用邮件通知
SEND_EMAIL_ALERTS=False

# SMTP服务器
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# 邮箱账号
SENDER_EMAIL=your-email@gmail.com

# 邮箱密码/应用密码
SENDER_PASSWORD=your-app-password

# 收件人 (多个用逗号分隔)
ALERT_RECIPIENTS=recipient@example.com,another@example.com

# ==================== 功能开关 ====================

# 启用AI预测
FEATURE_PREDICT_AI=True

# 启用自动预警
FEATURE_AUTO_ALERT=True

# 启用邮件通知
FEATURE_EMAIL_NOTIFY=False

# 启用短信通知 (需要集成短信服务)
FEATURE_SMS_NOTIFY=False

# ==================== 第三方服务 (可选) ====================

# Sentry 错误跟踪 (可选)
# SENTRY_DSN=https://xxx@sentry.io/xxx

# 阿里云OSS (数据备份)
# ALIYUN_ACCESS_KEY=xxx
# ALIYUN_SECRET_KEY=xxx
# ALIYUN_BUCKET_NAME=xxx

# 钉钉机器人Webhook (告警通知，可选)
# DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=xxx

# 企业微信机器人Webhook (告警通知，可选)
# WECHAT_WEBHOOK=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxx

# ==================== 生产环境必需配置 ====================

# 以下配置在生产环境中必须设置

# 1. 更改SECRET_KEY为强随机密钥
#    生成: python -c "import secrets; print(secrets.token_urlsafe(32))"
# SECRET_KEY=生成的密钥

# 2. 设置DEBUG=False
# DEBUG=False

# 3. 配置正确的ALLOWED_ORIGINS
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# 4. 使用生产级数据库 (PostgreSQL等)
# DATABASE_URL=postgresql://user:password@localhost:5432/finance_db

# 5. 启用访问日志
# ACCESS_LOG=True

# 6. 配置日志级别为WARNING/ERROR
# LOG_LEVEL=WARNING

# ==================== 开发环境推荐配置 ====================

# FLASK_ENV=development
# DEBUG=True
# LOG_LEVEL=DEBUG
# USE_FULL_MARKET=False
# MAX_A_STOCKS=100  # 小数据集加快开发速度
# MAX_HK_STOCKS=20
# MAX_US_STOCKS=20

# ==================== 模板使用说明 ====================

"""
配置步骤:

1. 复制此文件
   $ cp .env.example .env

2. 编辑 .env 文件，填入必需的配置:
   - TUSHARE_TOKEN (数据采集必需)
   - SECRET_KEY (生产环境修改)
   - ALLOWED_ORIGINS (安全性)

3. 可选配置 (邮件告警等):
   - SEND_EMAIL_ALERTS
   - SMTP_SERVER / SENDER_EMAIL / SENDER_PASSWORD

4. 启动应用
   $ python run.py
   或
   $ flask run

注意事项:

✅ 禁止将 .env 文件提交到版本控制系统
✅ 不要在代码中硬编码敏感信息
✅ 定期更新 Tushare token
✅ 生产环境使用强密钥和HTTPS
✅ 定期检查日志中的错误信息

安全建议:

🔒 生产环境配置:
  - 关闭DEBUG模式
  - 使用环境变量管理所有敏感信息
  - 启用HTTPS和验证
  - 限制API访问
  - 定期备份数据库
  - 监控系统日志和性能

📧 告警和通知:
  - 配置邮件提醒
  - 集成钉钉/企业微信
  - 设置重要投资决策的人工审核

🔄 定期维护:
  - 每周检查日志
  - 每月复盘投资表现
  - 每季度评估模型准确度
  - 每半年全面系统检查
"""

